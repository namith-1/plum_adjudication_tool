{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs",
        "node_modules/pdfjs-dist/standard_fonts/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
